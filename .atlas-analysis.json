  "keyFeatures": [
    "Vision LLM-powered API discovery from live web pages",
    "Auto-generates OpenAPI 3.0 specs from discovered site interactions",
    "Chrome extension captures browsing sessions for analysis",
    "REST API server for executing discovered actions",
    "Desktop Electron app with embedded browser for visual discovery",
    "Support for OpenAI, Anthropic, Gemini, and Ollama LLM providers",
    "Versioned manifests with semver-compatible contract diffing",
    "Swagger UI per discovered site for interactive exploration"
  ],
  "publicApiSurface": [
    "GET /api/health",
    "GET /api/sites",
    "GET /api/docs",
    "GET /api/sites/:slug/manifest",
    "GET /api/sites/:slug/openapi.json",
    "GET /api/sites/:slug/docs",
    "GET /api/sites/:slug/views/:name",
    "POST /api/sites/:slug/actions/:name",
    "POST /api/sites/:slug/workflows/:name",
    "browserwire CLI (npx browserwire)",
    "browserwire --host, --port, --debug flags",
    "browserwire --llm-provider, --llm-api-key flags",
    "browserwire --extension-path flag",
    "BROWSERWIRE_LLM_PROVIDER env var",
    "BROWSERWIRE_LLM_API_KEY env var",
    "BROWSERWIRE_LLM_MODEL env var",
    "BROWSERWIRE_LLM_BASE_URL env var",
    "BROWSERWIRE_HOST env var",
    "BROWSERWIRE_PORT env var",
    "~/.browserwire/config.json config file",
    "BrowserWireManifest TypeScript type",
    "WorkflowActionDef TypeScript type",
    "ActionDef TypeScript type",
    "ViewDef TypeScript type"
  ]
